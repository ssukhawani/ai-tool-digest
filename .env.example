# Copy this file to .env and fill in the values you have.
# Any variable left blank causes that source's check to be skipped (not failed).

# Product Hunt — https://www.producthunt.com/v2/oauth/applications
PH_DEVELOPER_TOKEN=

# Reddit — https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit requires a descriptive User-Agent per their API rules
REDDIT_USER_AGENT=ai-tool-digest/0.1 by <your_reddit_username>

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=
